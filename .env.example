# Flask Configuration
SECRET_KEY=your-secret-key-here
FLASK_ENV=development
FLASK_DEBUG=1

# Database
DATABASE_URL=postgresql://user:password@localhost/dbname

# S3/R2 Storage
S3_BUCKET=your-bucket-name
S3_KEY=your-s3-key
S3_SECRET_ACCESS_KEY=your-s3-secret
S3_ENDPOINT_URL=https://your-r2-endpoint.r2.cloudflarestorage.com
DOMAIN_NAME_IMAGES=https://your-image-cdn.com

# API Keys
DEEPINFRA_API_KEY=your-deepinfra-api-key
OPENAI_API_KEY=your-openai-api-key
RUNWARE_API_KEY=your-runware-api-key

# Gemini API (for classification)
GEMINI_API_KEY=your-gemini-api-key

# SpacetimeDB Chat
SPACETIMEDB_HTTP_URL=https://maincloud.spacetimedb.com
SPACETIMEDB_WS_URL=wss://maincloud.spacetimedb.com
SPACETIMEDB_DB_NAME=socialnetworkdotsocial-48xhr
SPACETIMEDB_DB_ID=c20069a056fa0538d26edbfe04785fe43b106f2fd5721f4a6555cf67f4090f93
SPACETIMEDB_SERVICE_TOKEN=your-spacetimedb-service-token
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SPACETIMEDB_TOKEN_ENCRYPTION_KEY=your-fernet-key
SPACETIMEDB_HTTP_TIMEOUT_SECONDS=15
